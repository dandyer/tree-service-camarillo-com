---
import { business } from '@data/business';
import { services } from '@data/services';
import { locations } from '@data/locations';
---

<footer class="bg-[--color-brand-dark] text-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand -->
      <div>
        <p class="text-xl font-bold mb-2">{business.name}</p>
        <p class="text-blue-200 text-sm mb-4">{business.tagline}</p>
        <a href={`tel:${business.phoneRaw}`} class="text-2xl font-bold text-white hover:text-blue-200 block mb-1">
          {business.phone}
        </a>
        <p class="text-blue-300 text-xs">{business.hours.weekdays}</p>
        <p class="text-blue-300 text-xs">{business.hours.saturday}</p>
      </div>

      <!-- Services -->
      <div>
        <h3 class="font-bold text-sm uppercase tracking-wider mb-4 text-blue-300">Services</h3>
        <ul class="space-y-2">
          {services.map(s => (
            <li><a href={`/services/${s.slug}`} class="text-blue-100 hover:text-white text-sm">{s.shortName}</a></li>
          ))}
          <li><a href="/services" class="text-blue-400 hover:text-white text-sm font-medium">All Services &rarr;</a></li>
        </ul>
      </div>

      <!-- Locations -->
      <div>
        <h3 class="font-bold text-sm uppercase tracking-wider mb-4 text-blue-300">Service Areas</h3>
        <ul class="space-y-2">
          {locations.slice(0, 7).map(l => (
            <li><a href={`/locations/${l.slug}`} class="text-blue-100 hover:text-white text-sm">{l.name}</a></li>
          ))}
          <li><a href="/locations" class="text-blue-400 hover:text-white text-sm font-medium">All Areas &rarr;</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-bold text-sm uppercase tracking-wider mb-4 text-blue-300">Contact</h3>
        <ul class="space-y-2 text-blue-100 text-sm">
          <li>{business.address.city}, {business.address.stateCode} {business.address.zip}</li>
          <li><a href={`mailto:${business.email}`} class="hover:text-white">{business.email}</a></li>
          <li class="mt-3">
            <button onclick="document.getElementById('contact-modal').showModal()"
                    class="bg-[--color-cta] hover:bg-[--color-cta-dark] text-white font-semibold px-5 py-2 rounded-lg text-sm transition">
              Get Free Estimate
            </button>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-white/10 mt-10 pt-6 text-center text-blue-400 text-xs">
      <p class="mb-2">{business.serviceArea}: {locations.map(l => l.name).join(' &middot; ')}</p>
      <p>&copy; {new Date().getFullYear()} {business.name}. All rights reserved.</p>
    </div>
  </div>
</footer>
