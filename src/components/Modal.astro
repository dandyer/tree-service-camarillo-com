---
import { business } from '@data/business';
---

<dialog id="contact-modal" class="w-full max-w-sm rounded-2xl shadow-2xl p-0 backdrop:bg-black/60 backdrop:backdrop-blur-sm">
  <div class="bg-(--color-brand-dark) px-6 py-4 flex items-center justify-between rounded-t-2xl">
    <div>
      <h2 class="text-white font-bold text-xl">Get Your Free Estimate</h2>
      <p class="text-blue-200 text-sm">{business.hours.weekdays} &middot; {business.hours.saturday}</p>
    </div>
    <button onclick="document.getElementById('contact-modal').close()"
            class="text-white/70 hover:text-white text-2xl leading-none">&times;</button>
  </div>

  <div class="flex flex-col gap-3 px-6 py-6">
    <a href={`tel:${business.phoneRaw}`}
       class="flex items-center justify-center gap-3 bg-(--color-brand) hover:bg-(--color-brand-dark) text-white font-bold text-lg py-4 rounded-xl transition">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
      </svg>
      Call {business.phone}
    </a>
    <a href={`sms:${business.phoneRaw}&body=Hi, I'd like a free estimate.`}
       class="flex items-center justify-center gap-3 bg-(--color-cta) hover:bg-(--color-cta-dark) text-white font-bold text-lg py-4 rounded-xl transition">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
      </svg>
      Text Us
    </a>
  </div>
</dialog>

