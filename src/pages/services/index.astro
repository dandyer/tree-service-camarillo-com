---
import Base from '@layouts/Base.astro';
import { business } from '@data/business';
import { services } from '@data/services';
---

<Base title={`${business.niche.replace(/\b\w/g,c=>c.toUpperCase())} Services | ${business.name}`}
     description={`Professional ${business.niche} services in ${business.address.city}, CA. ${business.jobsCompleted}+ jobs. Call ${business.phone}.`}
     canonical={`${business.website}/services`}>

  <section class="bg-(--color-brand-dark) text-white py-16 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-4xl font-bold mb-4">Our Services</h1>
      <p class="text-blue-200 text-lg">Professional {business.niche} services in {business.address.city} and surrounding areas.</p>
    </div>
  </section>

  <section class="py-16 bg-(--color-surface)">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(s => (
          <a href={`/services/${s.slug}`} class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md border border-gray-100 transition group">
            <h2 class="text-xl font-bold text-(--color-ink) mb-2 group-hover:text-(--color-brand)">{s.name}</h2>
            <p class="text-(--color-muted) text-sm mb-4">{s.description}</p>
            <p class="text-(--color-brand) text-sm font-medium">Learn more &rarr;</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-12 bg-(--color-brand-dark) text-white text-center">
    <div class="max-w-xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-4">Ready to Get Started?</h2>
      <a href={`tel:${business.phoneRaw}`} class="bg-white text-(--color-brand) font-bold text-xl px-8 py-4 rounded-xl hover:bg-blue-50 transition inline-block">
        {business.phone}
      </a>
    </div>
  </section>

</Base>
