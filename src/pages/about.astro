---
import Base from '@layouts/Base.astro';
import { business } from '@data/business';
import { content } from '@data/content';
---

<Base title={`About ${business.name} | ${business.address.city} ${business.niche}`}
     description={`${content.about.body[0] ?? business.tagline}`}
     canonical={`${business.website}/about`}>

  <section class="bg-[--color-brand-dark] text-white py-16 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-4xl font-bold mb-4">{content.about.heading}</h1>
      <p class="text-blue-200 text-lg">{business.tagline}</p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      {content.about.body.map(p => <p class="mb-5 text-[--color-muted] leading-relaxed text-lg">{p}</p>)}
      {content.about.ownerQuote && (
        <blockquote class="border-l-4 border-[--color-brand] pl-5 mt-8 italic text-[--color-ink] text-xl">
          "{content.about.ownerQuote}"
          <footer class="text-sm font-bold text-[--color-ink] mt-2 not-italic">— {business.owner.name}, {business.owner.title}</footer>
        </blockquote>
      )}
    </div>
  </section>

  <section class="py-12 bg-[--color-surface]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <p class="text-4xl font-bold text-[--color-brand]">{business.yearEstablished}</p>
          <p class="text-[--color-muted] text-sm mt-1">Year Founded</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <p class="text-4xl font-bold text-[--color-brand]">{business.experience}+</p>
          <p class="text-[--color-muted] text-sm mt-1">Years Experience</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <p class="text-4xl font-bold text-[--color-brand]">{business.jobsCompleted}+</p>
          <p class="text-[--color-muted] text-sm mt-1">Jobs Completed</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <p class="text-4xl font-bold text-[--color-brand]">{business.satisfaction}%</p>
          <p class="text-[--color-muted] text-sm mt-1">Satisfaction Rate</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 bg-[--color-brand-dark] text-white text-center">
    <div class="max-w-xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-4">Get Your Free Estimate Today</h2>
      <a href={`tel:${business.phoneRaw}`}
         class="bg-white text-[--color-brand] font-bold text-xl px-8 py-4 rounded-xl hover:bg-blue-50 transition inline-block">
        {business.phone}
      </a>
    </div>
  </section>

</Base>
